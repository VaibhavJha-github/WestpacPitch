# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Groq (fast STT + LLM)
GROQ_API_KEY=gsk_xxxxx

# Anthropic (Claude - for summaries)
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (fallback STT + TTS)
OPENAI_API_KEY=sk-proj-xxxxx

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=sk_xxxxx
USE_ELEVENLABS=1

# Voice IDs (ElevenLabs)
VOICE_ID_INDIAN_EN=EXAVITQu4vr4xnSDxMaL
VOICE_ID_AUSTRALIAN_EN=IKne3meq5aSn9XLyUdCD
DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# RunPod Serverless vLLM (optional backup)
RUNPOD_API_KEY=rpa_xxxxx
RUNPOD_ENDPOINT_ID=xxxxx
VLLM_BASE_URL=https://api.runpod.ai/v2/xxxxx/openai/v1
VLLM_MODEL=Qwen/Qwen3-4B

# Twilio (for phone calls + SMS)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+61xxxxxxxxx
CUSTOMER_PHONE_NUMBER=+61xxxxxxxxx
